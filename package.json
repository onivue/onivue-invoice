{
  "name": "onivue-invoice",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "17.4.2",
      "zod": "4.3.6",
      "typescript": "6.0.3",
      "@types/node": "25.6.0",
      "@neondatabase/serverless": "1.1.0",
      "@trpc/server": "11.16.0",
      "@trpc/client": "11.16.0",
      "react": "19.2.5",
      "react-dom": "19.2.5",
      "tailwindcss": "4.2.2",
      "@tailwindcss/vite": "4.2.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "serve": "bun run --filter '*' serve",
    "typecheck": "bun run --if-present --filter '*' typecheck",
    "dev:native": "bun run --filter native dev",
    "dev:web": "bun run --filter web dev",
    "db:push": "bun run --filter @onivue-invoice/db db:push",
    "db:studio": "bun run --filter @onivue-invoice/db db:studio",
    "db:generate": "bun run --filter @onivue-invoice/db db:generate",
    "db:migrate": "bun run --filter @onivue-invoice/db db:migrate",
    "db:local": "bun run --filter @onivue-invoice/db db:local",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@onivue-invoice/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@onivue-invoice/config": "workspace:*",
    "@types/node": "catalog:",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
